{
  "name": "foljapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Albanian verbal system reference",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "start": "npm run start --workspace=apps/web",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e --workspace=apps/web",
    "build:corpus": "tsx scripts/build-corpus.ts",
    "build:parallel-examples": "tsx scripts/build-parallel-examples.ts",
    "build:parallel-examples:local": "tsx scripts/build-parallel-examples.ts --from-local-cache",
    "build:corpus-targets": "tsx scripts/build-corpus-targets.ts",
    "build:local-corpus-index": "npm run build:corpus-targets && npm run scan:local-corpus",
    "scan:local-corpus": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- match --out=.cache/corpus-local-full.sqlite --sources=all --max-per-target=3 --jobs=12",
    "trace:corpus-targets": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- trace-targets",
    "report:corpus-coverage": "tsx scripts/report-corpus-coverage.ts",
    "audit:external-morphology": "node --experimental-strip-types scripts/audit-external-morphology.ts",
    "build:uniparser-analysis-requests": "node --experimental-strip-types scripts/build-uniparser-analysis-requests.ts",
    "run:uniparser-analysis": "PYTHONDONTWRITEBYTECODE=1 python3 scripts/run-uniparser-analysis.py",
    "audit:corpus-misses": "node --experimental-strip-types scripts/audit-corpus-misses.ts",
    "bench:corpus-search": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- bench",
    "build:corpus-search-index": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- build-search-index",
    "search:corpus": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- search-index",
    "download:opus": "tsx scripts/download-opus-corpora.ts",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.5.15",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
