{
  "name": "foljapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Albanian verbal system reference",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "start": "npm run start --workspace=apps/web",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e --workspace=apps/web",
    "build:corpus": "tsx scripts/build-corpus.ts",
    "build:parallel-examples": "tsx scripts/build-parallel-examples.ts",
    "build:parallel-examples:local": "tsx scripts/build-parallel-examples.ts --from-local-cache",
    "build:corpus-targets": "tsx scripts/build-corpus-targets.ts",
    "build:local-corpus-index": "npm run build:corpus-targets && npm run scan:local-corpus",
    "scan:local-corpus": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- match --out=.cache/corpus-local-full.sqlite --sources=all --max-per-target=3 --jobs=12",
    "build:corpus-candidate-cache": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- build-candidate-cache --sources=all --jobs=12 --cache-dir=.cache/corpus-candidate-shards/split-20260620",
    "scan:local-corpus:cached": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- match --out=.cache/corpus-local-full.sqlite --sources=all --max-per-target=3 --jobs=12 --candidate-cache-dir=.cache/corpus-candidate-shards/split-20260620 --require-candidate-cache",
    "trace:corpus-targets": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- trace-targets --candidate-cache-dir=.cache/corpus-candidate-shards/split-20260620",
    "report:corpus-raw-coverage": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- report-raw-coverage --candidate-cache-dir=.cache/corpus-candidate-shards/split-20260620",
    "report:corpus-coverage": "tsx scripts/report-corpus-coverage.ts",
    "report:corpus-phrase-variants": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- phrase-variant-stress --candidate-cache-dir=.cache/corpus-candidate-shards/split-20260620",
    "report:corpus-phrase-variants:plan": "npm run report:corpus-phrase-variants -- --plan-only",
    "report:corpus-phrase-variants:build-cache": "npm run report:corpus-phrase-variants -- --build-anchor-rows",
    "report:corpus-phrase-variants:all": "npm run report:corpus-phrase-variants -- --all-targets --out-json=.cache/corpus-phrase-variant-stress.all.json --out-md=.cache/corpus-phrase-variant-stress.all.md",
    "report:corpus-phrase-variants:all:plan": "npm run report:corpus-phrase-variants:all -- --plan-only",
    "report:corpus-phrase-variants:all:build-cache": "npm run report:corpus-phrase-variants:all -- --build-anchor-rows",
    "report:corpus-phrase-variants:all:chunk": "npm run report:corpus-phrase-variants -- --all-targets --chunk-size-targets=2000",
    "report:corpus-phrase-variants:all:chunk:plan": "npm run report:corpus-phrase-variants:all:chunk -- --plan-only",
    "report:corpus-phrase-variants:all:chunk:build-cache": "npm run report:corpus-phrase-variants:all:chunk -- --build-anchor-rows",
    "audit:external-morphology": "node --experimental-strip-types scripts/audit-external-morphology.ts",
    "check:middle-passive-review": "node --experimental-strip-types scripts/check-middle-passive-review.ts",
    "build:uniparser-analysis-requests": "node --experimental-strip-types scripts/build-uniparser-analysis-requests.ts",
    "run:uniparser-analysis": "PYTHONDONTWRITEBYTECODE=1 python3 scripts/run-uniparser-analysis.py",
    "audit:corpus-misses": "node --experimental-strip-types scripts/audit-corpus-misses.ts",
    "report:corpus-missing-forensics": "node --experimental-strip-types scripts/report-corpus-missing-forensics.ts",
    "audit:corpus-misses:full": "npm run build:uniparser-analysis-requests -- --kind=all --out=.cache/uniparser-analysis-requests.all-misses.jsonl && npm run run:uniparser-analysis -- --requests=.cache/uniparser-analysis-requests.all-misses.jsonl --out=.cache/uniparser-analysis.all-misses.jsonl && npm run audit:external-morphology -- --uniparser-analysis=.cache/uniparser-analysis.all-misses.jsonl && npm run audit:corpus-misses -- --morphology=.cache/external-morphology-audit.json",
    "bench:corpus-search": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- bench",
    "build:corpus-search-index": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- build-search-index",
    "search:corpus": "CARGO_TARGET_DIR=.cache/cargo-target cargo run --release --manifest-path tools/corpus-indexer/Cargo.toml -- search-index",
    "download:opus": "tsx scripts/download-opus-corpora.ts",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.5.15",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
