{
  "name": "foljapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Albanian verbal system reference",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "start": "npm run start --workspace=apps/web",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e --workspace=apps/web",
    "build:corpus": "tsx scripts/build-corpus.ts",
    "build:opus-examples": "tsx scripts/build-opus-examples.ts",
    "download:opus": "tsx scripts/download-opus-corpora.ts",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.5.15",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
